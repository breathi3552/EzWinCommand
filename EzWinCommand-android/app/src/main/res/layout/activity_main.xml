<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ezwin_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/app_name"
            android:textColor="@color/ezwin_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/main_activity_subtitle"
            android:textColor="@color/ezwin_text_muted"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/connectionStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/ez_panel"
            android:text="@string/main_status_idle"
            android:textColor="@color/ezwin_text"
            android:textSize="14sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/ez_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_pc_address_label"
                android:textColor="@color/ezwin_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/main_pc_address_help"
                android:textColor="@color/ezwin_text_muted"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/pcAddressInput"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:autofillHints="url"
                    android:background="@drawable/ez_input"
                    android:hint="@string/main_pc_address_hint"
                    android:inputType="textUri"
                    android:minHeight="48dp"
                    android:textColor="@color/ezwin_text"
                    android:textColorHint="@color/ezwin_text_muted" />

                <EditText
                    android:id="@+id/pcPortInput"
                    android:layout_width="96dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:autofillHints="postalCode"
                    android:background="@drawable/ez_input"
                    android:hint="@string/main_pc_port_hint"
                    android:inputType="number"
                    android:minHeight="48dp"
                    android:textColor="@color/ezwin_text"
                    android:textColorHint="@color/ezwin_text_muted" />
            </LinearLayout>

            <Button
                android:id="@+id/testConnectionButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/ez_button_primary"
                android:minHeight="52dp"
                android:text="@string/main_test_connection"
                android:textAllCaps="false"
                android:textColor="@color/ezwin_text"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/ez_panel"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/main_pairing_label"
                android:textColor="@color/ezwin_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/main_pairing_help"
                android:textColor="@color/ezwin_text_muted"
                android:textSize="12sp" />

            <EditText
                android:id="@+id/pairingCodeInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:autofillHints="smsOTP"
                android:background="@drawable/ez_input"
                android:fontFamily="monospace"
                android:gravity="center"
                android:hint="@string/main_pairing_code_hint"
                android:inputType="text"
                android:letterSpacing="0.3"
                android:maxLength="4"
                android:minHeight="64dp"
                android:textColor="@color/ezwin_text"
                android:textColorHint="@color/ezwin_text_muted"
                android:textSize="28sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/deviceNameInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:autofillHints="name"
                android:background="@drawable/ez_input"
                android:hint="@string/main_device_name_hint"
                android:inputType="textPersonName"
                android:minHeight="48dp"
                android:textColor="@color/ezwin_text"
                android:textColorHint="@color/ezwin_text_muted" />

            <Button
                android:id="@+id/pairButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/ez_button_primary"
                android:minHeight="52dp"
                android:text="@string/main_pair_button"
                android:textAllCaps="false"
                android:textColor="@color/ezwin_text"
                android:textStyle="bold" />
        </LinearLayout>

        <FrameLayout
            android:id="@+id/controlContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>
