# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
venv/

# 环境变量（包含敏感信息）
.env

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store


# 本地配置（首次运行自动创建，不纳入版本控制）
EzWinCommand-server/config.local.env
# 本机 Server 身份（包含私钥）
EzWinCommand-server/agent/server_identity.json
# OMP 工作流定义纳入版本控制；运行证据和本地辅助文件保持忽略
.omp/*
!.omp/AGENTS.md
!.omp/RULES.md
!.omp/agents/
!.omp/agents/**
!.omp/skills/
!.omp/skills/**
.agent/

# 当前产品与长期测试资料纳入版本控制；历史过程归档保持本地
docs/*
!docs/README.md
!docs/product-contract.md
!docs/protocol-contract.md
!docs/acceptance-coverage.md
!docs/changelog.md
!docs/product/
!docs/product/**
!docs/tests/
!docs/tests/**
!docs/versions/
!docs/versions/**


# 设备鉴权数据（运行时生成，包含本机配对 Key）
**/agent/devices.json
**/agent/plugins.json
**/agent/command_tasks.json

# 本地发布打包产物
EzWinCommand-v*.zip
icon-candidates/
# 测试产物
test_screenshots/
